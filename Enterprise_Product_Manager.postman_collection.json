                { "key": "limit", "value": "20", "description": "Items per page (default: 20)" },
                { "key": "search", "value": "", "description": "Search by name or category", "disabled": true },
                { "key": "categoryId", "value": "", "description": "Filter by category UUID", "disabled": true },
                { "key": "sortBy", "value": "createdAt", "description": "Sort field: name | price | createdAt", "disabled": true },
                { "key": "sortOrder", "value": "desc", "description": "asc | desc", "disabled": true },
                { "key": "minPrice", "value": "0", "description": "Minimum price filter", "disabled": true },
                { "key": "maxPrice", "value": "10000", "description": "Maximum price filter", "disabled": true },
                { "key": "startDate", "value": "2026-01-01", "description": "Created after (ISO date)", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "description": "Created before (ISO date)", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('productId', json.data[0].id);",
                  "    console.log('productId set to:', json.data[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
